# Copy this file to .env and fill in your values.
# Never commit the actual .env file to git.

# Your OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Path to the CV/resume PDF, relative to the backend/ directory
CV_PATH=data/your_cv.pdf

# Directory where ChromaDB will store the vectorstore (created automatically)
CHROMA_DIR=vectorstore

# OpenAI chat model used to generate answers
# Options: gpt-4o-mini (recommended), gpt-3.5-turbo, gpt-4o
MODEL_NAME=gpt-4o-mini

# OpenAI embedding model used to index and search the CV
# Must be the same model for both ingest.py and rag.py
# Options: text-embedding-3-small (recommended), text-embedding-3-large, text-embedding-ada-002
EMBEDDING_MODEL=text-embedding-3-small
